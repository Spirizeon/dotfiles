alias vim="nvim"
alias listnix="sudo nix-env --list-generations --profile /nix/var/nix/profiles/system"
alias deletenix="sudo nix-env --profile /nix/var/nix/profiles/system --delete-generations"
alias ls="eza -al"
alias confignix="sudo nvim /etc/nixos/configuration.nix"
alias buildnix="sudo nixos-rebuild switch"
nitch
